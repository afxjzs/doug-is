# Supabase credentials
# Never commit your actual .env.local file to your repository

# LOCAL DEV DATABASE (recommended)
# Used automatically in local development (NODE_ENV=development)
NEXT_PUBLIC_SUPABASE_URL_LOCAL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY_LOCAL=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY_LOCAL=your-local-service-role-key

# PRODUCTION DATABASE (hosted Supabase)
# Used in production environments and as fallback in non-local contexts
NEXT_PUBLIC_SUPABASE_URL=your-production-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-supabase-anon-key

# PRIVATE - Used for server-side operations (admin/protected operations)
# This key gives full database access and should NEVER be exposed to clients
# It should only be used in:
# - Server components
# - API routes
# - Server actions
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Setup Row Level Security (RLS) in your Supabase database
# to ensure that even if anon key is exposed, data is protected 